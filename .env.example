# ─────────────────────────────────────────────────────────────
# Bookr configuration — copy to .env and fill in.
# Nothing personal/deployment-specific is committed; it all lives here.
# ─────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────
PORT=8080
# Base URL the dashboard/ingest endpoint is reached at (for deep links in alerts)
PUBLIC_BASE_URL=http://localhost:8080
# Poll cadence (seconds). Jitter is a fraction in [0,1] added on top of each interval (one-sided,
# so the interval is a floor and passes never fire faster than POLL_INTERVAL_SECONDS).
POLL_INTERVAL_SECONDS=60
POLL_JITTER_PCT=0.25
# Express "trust proxy" hop count. 1 = trust exactly one reverse proxy (the TLS terminator).
# Set to 0 when nothing fronts the app, so client IPs (rate-limit keys) can't be spoofed.
TRUST_PROXY=1

# ── Credentials provider ─────────────────────────────────────
# Which credentials source to use: "env" (default, below) or "vaultwarden".
CREDENTIALS_PROVIDER=env

# --- env provider: hardcode creds here (simplest) ---
# Per booking provider, keyed by provider name (uppercased):
CRED_RESY_USERNAME=
CRED_RESY_PASSWORD=
CRED_RESY_API_KEY=          # Resy public web api_key (not a personal secret)
# App secrets:
APPRISE_KEY=               # apprise config key for urgent alerts
INGEST_TOKEN=              # bearer token guarding POST /api/ingest/:provider
UI_PASSWORD=               # single-user dashboard password
SESSION_SECRET=            # REQUIRED: signs the dashboard session cookie; generate a long random value

# --- vaultwarden provider: set CREDENTIALS_PROVIDER=vaultwarden, fill these ---
# (Generic — your folder/host/item names live ONLY here, never in source.)
# VW_SERVER=https://vault.example.com
# VW_FOLDER=Bookr
# VW_ITEM_PREFIX=
# BW_CLIENTID=
# BW_CLIENTSECRET=
# BW_PASSWORD=

# ── Notifications (apprise) ──────────────────────────────────
# Base URL of your apprise API server (the stateful /notify/<key> flavor).
APPRISE_URL=http://localhost:8000

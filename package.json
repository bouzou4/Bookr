{
  "name": "bookr",
  "version": "0.0.0",
  "private": true,
  "description": "Pluggable reservation scanner — watches booking providers (Resy first) for newly-freed reservations and alerts you.",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "ci": "pnpm typecheck && pnpm lint && pnpm test",
    "dev:server": "pnpm --filter @bookr/server dev",
    "dev:web": "pnpm --filter @bookr/web dev",
    "dev:mcp": "pnpm --filter @bookr/mcp dev",
    "cli": "pnpm --filter @bookr/cli start --",
    "scan": "pnpm --filter @bookr/cli start -- scan",
    "login": "pnpm --filter @bookr/login-tool start"
  },
  "devDependencies": {
    "typescript": "catalog:",
    "tsx": "catalog:",
    "vitest": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "eslint": "catalog:",
    "typescript-eslint": "catalog:",
    "eslint-plugin-jsdoc": "catalog:",
    "eslint-plugin-tsdoc": "catalog:"
  }
}
